@model Pedidos360.Models.Categoria

@{
    ViewData["Title"] = "Detalle de categoría";
}

<h1>Detalle de categoría</h1>

<div class="card p-3" style="max-width: 480px;">
    <dl class="row mb-0">
        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Nombre)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Nombre)</dd>

        <dt class="col-sm-4">Productos en esta categoría</dt>
        <dd class="col-sm-8">@Model.Productos.Count</dd>
    </dl>
</div>

<div class="mt-3 acciones-fila">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Volver a la lista</a>
</div>
