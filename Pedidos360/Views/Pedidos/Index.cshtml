@model IEnumerable<Pedidos360.Models.Pedido>

@{
    ViewData["Title"] = "Pedidos";
}

<h1>Pedidos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nuevo pedido</a>
</p>

@if (!Model.Any())
{
    <p>Todavía no hay pedidos registrados.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>N°</th>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Cliente?.Nombre</td>
                    <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.Total.ToString("C", System.Globalization.CultureInfo.CurrentCulture)</td>
                    <td>@item.Estado</td>
                    <td class="acciones-fila">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
