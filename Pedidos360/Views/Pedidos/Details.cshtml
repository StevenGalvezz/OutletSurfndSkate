@model Pedidos360.Models.Pedido

@{
    ViewData["Title"] = $"Pedido #{Model.Id}";
    var cultura = System.Globalization.CultureInfo.CurrentCulture;
}

<h1>Pedido #@Model.Id</h1>

<div class="card p-3 mb-3">
    <dl class="row mb-0">
        <dt class="col-sm-2">Cliente</dt>
        <dd class="col-sm-10">@Model.Cliente?.Nombre (@Model.Cliente?.Cedula)</dd>

        <dt class="col-sm-2">Fecha</dt>
        <dd class="col-sm-10">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</dd>

        <dt class="col-sm-2">Estado</dt>
        <dd class="col-sm-10">@Model.Estado</dd>
    </dl>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Cantidad</th>
            <th>Precio unit.</th>
            <th>Descuento</th>
            <th>Impuesto</th>
            <th>Total línea</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var linea in Model.Detalles)
        {
            <tr>
                <td>@linea.Producto?.Nombre</td>
                <td>@linea.Cantidad</td>
                <td>@linea.PrecioUnit.ToString("C", cultura)</td>
                <td>@linea.Descuento.ToString("C", cultura)</td>
                <td>@linea.ImpuestoPorc %</td>
                <td>@linea.TotalLinea.ToString("C", cultura)</td>
            </tr>
        }
    </tbody>
</table>

<div class="card p-3 resumen-totales" style="max-width: 320px; margin-left: auto;">
    <div class="fila"><span>Subtotal</span><span>@Model.Subtotal.ToString("C", cultura)</span></div>
    <div class="fila"><span>Impuestos</span><span>@Model.Impuestos.ToString("C", cultura)</span></div>
    <div class="fila total"><span>Total</span><span>@Model.Total.ToString("C", cultura)</span></div>
</div>

<p class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Volver a la lista</a>
</p>
