@model Pedidos360.Models.Cliente

@{
    ViewData["Title"] = "Eliminar cliente";
}

<h1>Eliminar cliente</h1>

<p>¿Seguro que quiere eliminar este cliente?</p>

<div class="card p-3" style="max-width: 480px;">
    <dl class="row mb-0">
        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Nombre)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Nombre)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Cedula)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Cedula)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Correo)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Correo)</dd>
    </dl>

    <form asp-action="Delete" class="mt-3 acciones-fila">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Eliminar" class="btn btn-sm btn-danger" />
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Cancelar</a>
    </form>
</div>
