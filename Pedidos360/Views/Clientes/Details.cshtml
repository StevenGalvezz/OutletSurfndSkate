@model Pedidos360.Models.Cliente

@{
    ViewData["Title"] = "Detalle de cliente";
}

<h1>Detalle de cliente</h1>

<div class="card p-3" style="max-width: 480px;">
    <dl class="row mb-0">
        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Nombre)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Nombre)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Cedula)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Cedula)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Correo)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Correo)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Telefono)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Telefono)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Direccion)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Direccion)</dd>
    </dl>
</div>

<div class="mt-3 acciones-fila">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Volver a la lista</a>
</div>
