@model Pedidos360.Models.Producto

@{
    ViewData["Title"] = "Detalle de producto";
}

<h1>Detalle de producto</h1>

<div class="card p-3" style="max-width: 480px;">
    <div style="max-width: 200px;">
        <partial name="_ImagenProducto" model="(Model.ImagenUrl, Model.Nombre)" />
    </div>
    <dl class="row mb-0 mt-3">
        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Nombre)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Nombre)</dd>

        <dt class="col-sm-4">Categoría</dt>
        <dd class="col-sm-8">@Model.Categoria?.Nombre</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Precio)</dt>
        <dd class="col-sm-8">@Model.Precio.ToString("C", System.Globalization.CultureInfo.CurrentCulture)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.ImpuestoPorc)</dt>
        <dd class="col-sm-8">@Model.ImpuestoPorc %</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Stock)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Stock)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.ImagenUrl)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.ImagenUrl)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Activo)</dt>
        <dd class="col-sm-8">@(Model.Activo ? "Sí" : "No")</dd>
    </dl>
</div>

<div class="mt-3 acciones-fila">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Volver a la lista</a>
</div>
