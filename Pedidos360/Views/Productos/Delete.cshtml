@model Pedidos360.Models.Producto

@{
    ViewData["Title"] = "Eliminar producto";
}

<h1>Eliminar producto</h1>

<p>¿Seguro que quiere eliminar este producto?</p>

<div class="card p-3" style="max-width: 480px;">
    <dl class="row mb-0">
        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Nombre)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Nombre)</dd>

        <dt class="col-sm-4">Categoría</dt>
        <dd class="col-sm-8">@Model.Categoria?.Nombre</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Precio)</dt>
        <dd class="col-sm-8">@Model.Precio.ToString("C", System.Globalization.CultureInfo.CurrentCulture)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Stock)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Stock)</dd>
    </dl>

    <form asp-action="Delete" class="mt-3 acciones-fila">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Eliminar" class="btn btn-sm btn-danger" />
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Cancelar</a>
    </form>
</div>
