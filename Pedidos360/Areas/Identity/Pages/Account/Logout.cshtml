@page
@model LogoutModel
@{
    ViewData["Title"] = "Cerrar sesión";
}

<header>
    <h1>@ViewData["Title"]</h1>
    @{
        if (User.Identity?.IsAuthenticated ?? false)
        {
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="nav-link btn btn-link text-dark">Salir</button>
            </form>
        }
        else
        {
            <p>Cerró sesión correctamente.</p>
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Volver al inicio</a>
        }
    }
</header>
